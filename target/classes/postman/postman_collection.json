  "item": [
    {
      "name": "Role",
      "item": [
        {
          "name": "Get Roles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/roles?page=0&size=10&role_code=ADMIN&is_active=true",
              "host": ["{{baseUrl}}"],
              "path": ["roles"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "role_code", "value": "ADMIN" },
                { "key": "is_active", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/roles",
              "host": ["{{baseUrl}}"],
              "path": ["roles"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleCode\": \"HR\",\n  \"roleName\": \"Human Resources\"\n}"
            }
          }
        },
        {
          "name": "Get Role By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/roles/1",
              "host": ["{{baseUrl}}"],
              "path": ["roles", "1"]
            }
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/roles/1",
              "host": ["{{baseUrl}}"],
              "path": ["roles", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"Admin Updated\"\n}"
            }
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/roles/1",
              "host": ["{{baseUrl}}"],
              "path": ["roles", "1"]
            }
          }
        }
      ]
    },
