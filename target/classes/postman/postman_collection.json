{
  "info": {
    "name": "Master Data Service - v1",
    "description": "CRUD APIs for Master Data with pagination and soft delete",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081/api/v1"
    }
